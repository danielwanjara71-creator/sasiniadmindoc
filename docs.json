{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sasini Admin Dashboard",
  "logo": {
    "dark": "/logo/sasini-text-logo.svg",
    "light": "/logo/sasini-text-logo.svg",
    "href": "/"
  },
  "colors": {
    "primary": "#2C9144",
    "light": "#76BD22",
    "dark": "#1E6830"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Sasini Website",
        "href": "https://sasini.co.ke"
      },
      {
        "label": "Help & Support",
        "href": "/support/help-center"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sasiniplc",
      "instagram": "https://www.instagram.com/sasiniplc/?hl=en",
      "facebook": "https://www.facebook.com/SasiniTeaandCoffee",
      "linkedin": "https://ke.linkedin.com/company/sasini-plc",
      "youtube": "https://www.youtube.com/channel/UCtwz5m5FWhxy-qub0N5F-MQ"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Admin Console",
        "groups": [
          {
            "group": "System Overview",
            "pages": ["index", "login-access", "roles-permissions"]
          },
          {
            "group": "Core Modules",
            "pages": [
              "dashboard-home",
              "pickups",
              "orders-agrishop",
              "pest-reports",
              "community-users",
              "feedback-ratings",
              "notifications"
            ]
          },
          {
            "group": "Administration",
            "pages": ["iam-management", "activity-logs"]
          }
        ]
      }
    ]
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "styling": {
    "codeblocks": "dark"
  }
}
